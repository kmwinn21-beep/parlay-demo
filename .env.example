# ─── Database (Turso / libSQL) ────────────────────────────────────────────────
# Get these from your Turso dashboard: https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Authentication ───────────────────────────────────────────────────────────
# Random secret used to sign JWT session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 characters. REQUIRED in production.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ─── Application URL ──────────────────────────────────────────────────────────
# Used to build absolute links in emails (verification, password reset).
# In development this defaults to http://localhost:3000.
# On Netlify this is automatically set via NEXT_PUBLIC_URL or DEPLOY_URL.
NEXT_PUBLIC_BASE_URL=https://your-site.netlify.app

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# If SMTP_HOST is not set, email links are printed to the server console instead
# (useful for local development). All fields below are required for production.
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_SECURE=false          # set to "true" for port 465 (TLS)
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Conference Hub <noreply@procarehr.com>"

# ─── Email Outreach: Google OAuth (Gmail sending) ────────────────────────────
# Create a project at console.cloud.google.com, enable Gmail API,
# then Credentials → OAuth 2.0 Client ID (Web). Redirect URI:
#   https://your-domain/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email Outreach: Microsoft OAuth (Outlook / M365 sending) ────────────────
# Register an app at portal.azure.com → App registrations.
# Grant delegated permissions: Mail.Send, offline_access. Redirect URI:
#   https://your-domain/api/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ─── Anthropic API (card/badge scanner OCR) ───────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Cloudflare R2 (logo / image uploads) ────────────────────────────────────
# Account ID: Cloudflare dashboard → R2 → top-right corner
R2_ACCOUNT_ID=your-cloudflare-account-id
# Create an API token at: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# The name of your R2 bucket
R2_BUCKET_NAME=parlaybucket
# Public URL: Cloudflare dashboard → R2 → your bucket → Settings → Public access
R2_PUBLIC_URL=https://pub-aab081b1e6284abf9266a4f4a7a8f695.r2.dev
